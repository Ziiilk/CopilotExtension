          "action": { "type": "builtin", "command": "memory" }
        },
        {
          "label": "Terminals",
          "icon": "terminal",
          "tooltip": "点击清理空闲终端；下拉可勾选「仅打开终端查看器」",
          "action": { "type": "builtin", "command": "terminals" }
        }
      ]
    },
    {
      "buttons": [
        {
          "label": "Simplify",
          "icon": "sparkle",
