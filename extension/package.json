{
  "name": "copilot-extension-panel",
  "displayName": "Copilot Extension Panel",
  "description": "A row of text buttons under Copilot Chat that run your *.prompt.md files as /commands.",
  "version": "0.1.0",
  "publisher": "local",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "panel": [
        {
          "id": "copilotExtensionContainer",
          "title": "Copilot Extension",
          "icon": "$(rocket)"
        }
      ]
    },
    "views": {
      "copilotExtensionContainer": [
        {
          "type": "webview",
          "id": "copilotExtension.panel",
          "name": "Copilot Extension",
          "icon": "$(rocket)"
        }
      ]
    },
    "commands": [
      {
        "command": "copilotExtension.enableInjection",
        "title": "Copilot Extension: 应用配置"
      },
      {
        "command": "copilotExtension.restoreDefault",
        "title": "Copilot Extension: 恢复默认"
      },
      {
        "command": "copilotExtension.editConfig",
        "title": "Copilot Extension: 编辑配置"
      }
    ]
  }
}
